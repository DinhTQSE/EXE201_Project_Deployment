# Copy this file to .env for local development.
# Do not commit .env.

DB_URL=jdbc:postgresql://localhost:5432/vsign
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public

JWT_SECRET=replace-with-a-local-dev-secret-at-least-32-characters
JWT_EXPIRATION_MS=150000000
JWT_REFRESH_EXPIRATION_MS=1512000000

