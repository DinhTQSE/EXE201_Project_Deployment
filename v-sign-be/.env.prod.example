# Copy this file to .env.prod on the production server.
# Do not commit .env.prod.

DB_URL=jdbc:postgresql://host:5432/database
DB_USER=vsign
DB_PASSWORD=change-me
DB_SCHEMA=public

JWT_SECRET=replace-with-production-secret-at-least-32-characters
JWT_EXPIRATION_MS=150000000
JWT_REFRESH_EXPIRATION_MS=1512000000

APP_CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
AI_SERVICE_BASE_URL=http://ai:8000
AI_SERVICE_PREDICT_TIMEOUT_MS=10000
