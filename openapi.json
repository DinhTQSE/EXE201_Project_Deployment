{
  "openapi": "3.0.3",
  "info": {
    "title": "V-Sign FE-first API Contract",
    "version": "0.1.0",
    "description": "Contract emitted from frontend remediation. Backend is standby until this contract is reviewed."
  },
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "security": [],
        "summary": "Register a learner account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "409": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "security": [],
        "summary": "Login with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthSessionResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/auth/password-reset/request": {
      "post": {
        "security": [],
        "summary": "Request password reset email without revealing account existence",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PasswordResetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/EmptySuccess"
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Get current user profile",
        "responses": {
          "200": {
            "description": "Current user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponseEnvelope"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/me/profile": {
      "patch": {
        "summary": "Update current user profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProfileResponseEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/me/change-password": {
      "post": {
        "summary": "Change current user password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/EmptySuccess"
          },
          "400": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/dictionary": {
      "get": {
        "security": [],
        "summary": "Public VSL dictionary search",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "difficulty",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/Difficulty"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "size",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Dictionary page",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DictionaryPageEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/dictionary/{entryId}/practice-target": {
      "get": {
        "security": [],
        "summary": "Resolve dictionary entry practice target",
        "parameters": [
          {
            "name": "entryId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Practice target",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PracticeTargetEnvelope"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/lessons/{lessonId}/progress": {
      "put": {
        "summary": "Persist lesson checkpoint or completion",
        "parameters": [
          {
            "name": "lessonId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LessonProgressRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Progress persisted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LessonProgressEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/gamification/xp-awards": {
      "post": {
        "summary": "Idempotently award XP for lesson or quiz events",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/XpAwardRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "XP award result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/XpAwardEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/subscription/plans": {
      "get": {
        "summary": "List available Premium plans",
        "responses": {
          "200": {
            "description": "Plan list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentPlansEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/me/subscription": {
      "get": {
        "summary": "Get current subscription summary",
        "responses": {
          "200": {
            "description": "Subscription summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubscriptionEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/me/payments": {
      "get": {
        "summary": "Get current user payment history",
        "responses": {
          "200": {
            "description": "Payment history",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentHistoryEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/payments/orders": {
      "post": {
        "summary": "Create QR payment order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePaymentOrderRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Payment order",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentOrderEnvelope"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    },
    "/payments/{transactionId}": {
      "get": {
        "summary": "Poll payment status",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment transaction status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentTransactionEnvelope"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ApiError"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "responses": {
      "EmptySuccess": {
        "description": "Empty success envelope",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/EmptyEnvelope"
            }
          }
        }
      },
      "ApiError": {
        "description": "Normalized API error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ApiErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "SuccessBase": {
        "type": "object",
        "required": ["success", "message", "timestamp"],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "EmptyEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "nullable": true
              }
            }
          }
        ]
      },
      "ApiErrorResponse": {
        "type": "object",
        "required": ["timestamp", "status", "error", "code", "message", "path"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          },
          "code": {
            "type": "string",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "validationErrors": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "AccountType": {
        "type": "string",
        "enum": ["BASIC", "PREMIUM", "ADMIN"]
      },
      "Difficulty": {
        "type": "string",
        "enum": ["CO_BAN", "TRUNG_BINH", "NANG_CAO"]
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["displayName", "email", "password"],
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "PasswordResetRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "ChangePasswordRequest": {
        "type": "object",
        "required": ["currentPassword", "newPassword"],
        "properties": {
          "currentPassword": {
            "type": "string"
          },
          "newPassword": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "AuthUser": {
        "type": "object",
        "required": ["id", "email", "displayName", "accountType"],
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "accountType": {
            "$ref": "#/components/schemas/AccountType"
          }
        }
      },
      "AuthSession": {
        "type": "object",
        "required": ["accessToken", "user"],
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/AuthUser"
          }
        }
      },
      "AuthSessionResponse": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/AuthSession"
              }
            }
          }
        ]
      },
      "ProfileResponseEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/AuthUser"
              }
            }
          }
        ]
      },
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          }
        }
      },
      "DictionaryEntry": {
        "type": "object",
        "required": ["id", "word", "category", "difficulty", "description"],
        "properties": {
          "id": {
            "type": "integer"
          },
          "word": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "difficulty": {
            "$ref": "#/components/schemas/Difficulty"
          },
          "description": {
            "type": "string"
          },
          "videoUrl": {
            "type": "string"
          },
          "thumbnailUrl": {
            "type": "string"
          }
        }
      },
      "DictionaryPage": {
        "type": "object",
        "required": ["items", "page", "size", "total"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DictionaryEntry"
            }
          },
          "page": {
            "type": "integer"
          },
          "size": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "DictionaryPageEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/DictionaryPage"
              }
            }
          }
        ]
      },
      "PracticeTarget": {
        "type": "object",
        "properties": {
          "entryId": {
            "type": "integer"
          },
          "lessonId": {
            "type": "integer"
          },
          "label": {
            "type": "string"
          },
          "requiresPremium": {
            "type": "boolean"
          }
        }
      },
      "PracticeTargetEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PracticeTarget"
              }
            }
          }
        ]
      },
      "LessonProgressRequest": {
        "type": "object",
        "required": ["status", "phase"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["IN_PROGRESS", "COMPLETED"]
          },
          "phase": {
            "type": "string",
            "enum": ["learn", "quiz"]
          },
          "videoTimeSeconds": {
            "type": "integer"
          },
          "completionPct": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          }
        }
      },
      "LessonProgress": {
        "type": "object",
        "properties": {
          "lessonId": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "phase": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LessonProgressEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/LessonProgress"
              }
            }
          }
        ]
      },
      "XpAwardRequest": {
        "type": "object",
        "required": ["eventId", "source", "xpDelta", "activityDate"],
        "properties": {
          "eventId": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": ["LESSON_COMPLETE", "QUIZ_COMPLETE", "STREAK_BONUS", "BADGE_EARN"]
          },
          "xpDelta": {
            "type": "integer"
          },
          "activityDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "XpAwardResult": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string"
          },
          "duplicate": {
            "type": "boolean"
          },
          "totalXp": {
            "type": "integer"
          },
          "currentStreak": {
            "type": "integer"
          },
          "longestStreak": {
            "type": "integer"
          }
        }
      },
      "XpAwardEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/XpAwardResult"
              }
            }
          }
        ]
      },
      "PaymentProvider": {
        "type": "string",
        "enum": ["MOMO", "ZALOPAY"]
      },
      "PlanType": {
        "type": "string",
        "enum": ["MONTHLY", "YEARLY"]
      },
      "PaymentStatus": {
        "type": "string",
        "enum": ["PENDING", "SUCCESS", "FAILED", "TIMEOUT"]
      },
      "PaymentPlan": {
        "type": "object",
        "properties": {
          "planType": {
            "$ref": "#/components/schemas/PlanType"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "integer"
          },
          "currency": {
            "type": "string",
            "enum": ["VND"]
          },
          "durationDays": {
            "type": "integer"
          }
        }
      },
      "PaymentPlansEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PaymentPlan"
                }
              }
            }
          }
        ]
      },
      "SubscriptionSummary": {
        "type": "object",
        "properties": {
          "planType": {
            "$ref": "#/components/schemas/PlanType"
          },
          "status": {
            "type": "string",
            "enum": ["FREE", "ACTIVE", "EXPIRED", "CANCELLED"]
          },
          "startedAt": {
            "type": "string",
            "format": "date-time"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "remainingDays": {
            "type": "integer"
          }
        }
      },
      "SubscriptionEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/SubscriptionSummary"
              }
            }
          }
        ]
      },
      "CreatePaymentOrderRequest": {
        "type": "object",
        "required": ["provider", "planType"],
        "properties": {
          "provider": {
            "$ref": "#/components/schemas/PaymentProvider"
          },
          "planType": {
            "$ref": "#/components/schemas/PlanType"
          }
        }
      },
      "PaymentOrder": {
        "type": "object",
        "properties": {
          "transactionId": {
            "type": "string"
          },
          "providerTransactionId": {
            "type": "string"
          },
          "provider": {
            "$ref": "#/components/schemas/PaymentProvider"
          },
          "planType": {
            "$ref": "#/components/schemas/PlanType"
          },
          "amount": {
            "type": "integer"
          },
          "currency": {
            "type": "string",
            "enum": ["VND"]
          },
          "status": {
            "$ref": "#/components/schemas/PaymentStatus"
          },
          "qrCodeData": {
            "type": "string"
          },
          "deepLink": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaymentTransaction": {
        "allOf": [
          {
            "$ref": "#/components/schemas/PaymentOrder"
          },
          {
            "type": "object",
            "properties": {
              "createdAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        ]
      },
      "PaymentOrderEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PaymentOrder"
              }
            }
          }
        ]
      },
      "PaymentTransactionEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "$ref": "#/components/schemas/PaymentTransaction"
              }
            }
          }
        ]
      },
      "PaymentHistoryEnvelope": {
        "allOf": [
          {
            "$ref": "#/components/schemas/SuccessBase"
          },
          {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/PaymentTransaction"
                }
              }
            }
          }
        ]
      }
    }
  }
}
