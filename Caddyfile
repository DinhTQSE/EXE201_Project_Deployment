{$APP_DOMAIN:localhost} {
    encode zstd gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    handle /api/v1/* {
        request_body {
            max_size 1MB
        }
        uri replace /api/v1 /V-sign/api/v1
        reverse_proxy backend:8080
    }

    handle {
        respond "Not found" 404
    }
}
